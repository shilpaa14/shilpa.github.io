// Smooth scroll
function scrollToSection(id) {
  document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
}

// Typing effect
const text = ["Software Engineer"];
let i = 0, j = 0, current = '', isDeleting = false;

function type() {
  current = text[i];

  if (!isDeleting) {
    document.getElementById("typing").innerText = current.substring(0, j++);
    if (j > current.length) {
      isDeleting = true;
      setTimeout(type, 1000);
      return;
    }
  } else {
    document.getElementById("typing").innerText = current.substring(0, j--);
    if (j < 0) {
      isDeleting = false;
      i = (i + 1) % text.length;
    }
  }

  setTimeout(type, isDeleting ? 50 : 100);
}

// Modal open
function openModal(project) {
  const modal = document.getElementById('modal');
  const content = document.getElementById('modal-content');

  if (project === 'erp') {
    content.innerHTML = `
      <h2>ERP System</h2>
      <p>Developed a full ERP system with user roles, reporting dashboard, and system integration.</p>
    `;
  }

  if (project === 'portfolio') {
    content.innerHTML = `
      <h2>Portfolio</h2>
      <p>Responsive portfolio with animations and modern UI.</p>
    `;
  }

  if (project === 'python') {
    content.innerHTML = `
      <h2>Automation</h2>
      <p>Python scripts for automation and efficiency improvement.</p>
    `;
  }

  modal.style.display = 'flex';
}

// ✅ Run everything after page loads
window.onload = function () {

  // Start typing animation
  type();

  // Close modal when clicking outside
  const modal = document.getElementById('modal');
  modal.onclick = function () {
    modal.style.display = 'none';
  };

};


