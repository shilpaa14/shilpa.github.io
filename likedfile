<!-- Modal -->
<div class="modal" id="modal">
  <div class="modal-content" id="modal-content"></div>
</div>

<script>
  function scrollToSection(id) {
    document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
  }

  // Typing effect
  const text = ["Python Developer", "Software Engineer", "Problem Solver"];
  let i = 0, j = 0, current = '', isDeleting = false;

  function type() {
    current = text[i];

    if (!isDeleting) {
      document.getElementById("typing").innerText = current.substring(0, j++);
      if (j > current.length) { isDeleting = true; setTimeout(type, 1000); return; }
    } else {
      document.getElementById("typing").innerText = current.substring(0, j--);
      if (j < 0) { isDeleting = false; i = (i + 1) % text.length; }
    }

    setTimeout(type, isDeleting ? 50 : 100);
  }
  type();

  // Modal
  function openModal(project) {
    const modal = document.getElementById('modal');
    const content = document.getElementById('modal-content');

    if (project === 'erp') {
      content.innerHTML = '<h2>ERP System</h2><p>Developed a full ERP system with user roles, reporting dashboard, and system integration.</p>';
    }
    if (project === 'portfolio') {
      content.innerHTML = '<h2>Portfolio</h2><p>Responsive portfolio with animations and modern UI.</p>';
    }
    if (project === 'python') {
      content.innerHTML = '<h2>Automation</h2><p>Python scripts for automation and efficiency improvement.</p>';
    }

    modal.style.display = 'flex';
  }

  document.getElementById('modal').onclick = function() {
    this.style.display = 'none';
  }
</script>

</body>
